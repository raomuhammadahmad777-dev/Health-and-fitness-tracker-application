class User {
    QString username;
    QString password;
    int day = 1;
    double daily = 0;
    double total = 0;
    QVector<double> history;
public:
    void set(QString u, QString p, int d, QVector<double> h, double da, double t) {
        username = u;
        password = p;
        day = d;
        history = h;
        daily = da;
        total = t;
    }

    QString u() { return username; }
    QString p() { return password; }
    int getDay() { return day; }
    double getTotal() { return total; }
    QVector<double> getHistory() { return history; }

    void add(double cal) {
        daily += cal;
    }

    void nextDay() {
        history.append(daily);
        total += daily;
        daily = 0;
        day++;
    }
};



class Exercise {
protected:
    QString name;
    QString duration;
    int calories;
public:
    Exercise(QString n, QString d, int c) : name(n), duration(d), calories(c) {}

    virtual ~Exercise() {}

    virtual QString getLabel() const = 0;

    int getCalories() const { return calories; }
};


class CardioExercise : public Exercise {
public:
    CardioExercise(QString n, QString d, int c) : Exercise(n, d, c) {}

    QString getLabel() const override {
        return name + "\n" + duration + " | " + QString::number(calories) + " kcal";              // running
    }                                                                                             // 20 min | 125 kcal
};


class StrengthExercise : public Exercise {
public:
    StrengthExercise(QString n, QString d, int c) : Exercise(n, d, c) {}

    QString getLabel() const override {
        return name + "\n" + duration + " | " + QString::number(calories) + " kcal";
    }
};
