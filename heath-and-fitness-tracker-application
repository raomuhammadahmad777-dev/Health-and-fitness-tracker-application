QWidget* start() {
    QWidget *w = new QWidget;
    QVBoxLayout *l = new QVBoxLayout;

    QPushButton *loginBtn = new QPushButton("Login");
    QPushButton *signupBtn = new QPushButton("Create Profile");

    l->addWidget(loginBtn);
    l->addWidget(signupBtn);

    QObject::connect(loginBtn, &QPushButton::clicked, []{ stack->setCurrentIndex(1); });
    QObject::connect(signupBtn, &QPushButton::clicked, []{ stack->setCurrentIndex(2); });

    w->setLayout(l);
    return w;
}


QWidget* login() {
    QWidget *w = new QWidget;
    QVBoxLayout *l = new QVBoxLayout;

    QLineEdit *u = new QLineEdit;
    QLineEdit *p = new QLineEdit;
    p->setEchoMode(QLineEdit::Password);

    QPushButton *btn = new QPushButton("Login");
    QPushButton *back = new QPushButton("Back");

    l->addWidget(new QLabel("Username"));
    l->addWidget(u);
    l->addWidget(new QLabel("Password"));
    l->addWidget(p);
    l->addWidget(btn);
    l->addWidget(back);

    QObject::connect(btn, &QPushButton::clicked, [=]() {
        if (load(u->text(), p->text())) {
            stack->removeWidget(stack->widget(3));
            stack->insertWidget(3, dashboard());
            stack->setCurrentIndex(3);
        } else {
            QMessageBox::warning(w, "Error", "Invalid login");
        }
    });

    QObject::connect(back, &QPushButton::clicked, []{ stack->setCurrentIndex(0); });

    w->setLayout(l);
    return w;
}


QWidget* signup() {
    QWidget *w = new QWidget;
    QVBoxLayout *l = new QVBoxLayout;

    QLineEdit *u = new QLineEdit;
    QLineEdit *p = new QLineEdit;

    QPushButton *create = new QPushButton("Create Profile");
    QPushButton *back = new QPushButton("Back");

    l->addWidget(new QLabel("Username"));
    l->addWidget(u);
    l->addWidget(new QLabel("Password"));
    l->addWidget(p);
    l->addWidget(create);
    l->addWidget(back);

    QObject::connect(create, &QPushButton::clicked, [=]() {
        if (u->text().isEmpty() || p->text().isEmpty()) {
            QMessageBox::warning(w, "Error", "Fill all fields");
            return;
        }
        current.set(u->text(), p->text(), 1, {}, 0, 0);
        save();
        QMessageBox::information(w, "Success", "Profile Created!");
        stack->setCurrentIndex(0);
    });

    QObject::connect(back, &QPushButton::clicked, []{ stack->setCurrentIndex(0); });

    w->setLayout(l);
    return w;
}

